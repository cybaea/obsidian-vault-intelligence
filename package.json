{
  "name": "obsidian-vault-intelligence",
  "version": "9.3.5",
  "description": "Research your vault with an AI agent powered by Google Gemini, discover related notes through semantic search, and analyze specific documents with contextual note referencing.",
  "author": "Allan Engelhardt",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "preversion": "npm run lint && npm run build",
    "version": "node version-bump.mjs && git add manifest.json versions.json CHANGELOG.md",
    "lint": "node scripts/lint-security.mjs && eslint . && npm run lint:css && npm run lint:secrets && npm run lint:md",
    "lint:css": "stylelint '**/*.css'",
    "lint:secrets": "secretlint \"**/*\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "upgrade-transformers": "node scripts/upgrade-transformers.cjs",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "release:prep": "node scripts/release-prep.mjs",
    "publish-pr": "bash scripts/publish-pr.sh",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "google-gemini-ai",
    "agentic-workflow",
    "semantic-search",
    "knowledge-management",
    "rag",
    "ontology",
    "pkm",
    "knowledge-graph",
    "local-first"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/js": "^10.0.0",
    "@eslint/json": "^1.0.0",
    "@nolebase/vitepress-plugin-og-image": "^2.18.2",
    "@secretlint/secretlint-rule-preset-recommend": "^12.0.0",
    "@types/node": "^24.10.13",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.0.17",
    "esbuild": "0.28.0",
    "esbuild-plugin-inline-worker": "0.1.1",
    "eslint": "^10.0.0",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "eslint-plugin-perfectionist": "^5.4.0",
    "globals": "^17.5.0",
    "graphology-types": "^0.24.8",
    "jiti": "^2.6.1",
    "markdownlint-cli2": "^0.22.0",
    "mermaid": "^11.12.2",
    "obsidian": "^1.12.2",
    "oxc-minify": "^0.127.0",
    "secretlint": "^12.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.56.0",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@msgpack/msgpack": "^3.1.3",
    "@orama/orama": "^3.1.18",
    "@orama/stopwords": "^3.1.18",
    "@xenova/transformers": "2.17.2",
    "comlink": "^4.4.2",
    "events": "^3.3.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "sharp": "0.34.5",
    "sigma": "^3.0.2",
    "zod": "^4.3.5",
    "zod-to-json-schema": "^3.25.1"
  },
  "overrides": {
    "esbuild": "0.28.0",
    "lodash-es": "4.18.1",
    "minimatch": "^10.0.0",
    "glob": "^13.0.0",
    "katex": "0.16.45",
    "flatted": "^3.4.2",
    "smol-toml": "^1.6.1",
    "sharp": "$sharp",
    "vite": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "vitepress": "2.0.0-alpha.17",
    "protobufjs": "^8.0.0",
    "uuid": "^14.0.0",
    "fetch-blob": "^4.0.0",
    "node-domexception": "file:./scripts/stubs/node-domexception"
  }
}
